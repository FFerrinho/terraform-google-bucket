# top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Makefiles use tabs
[Makefile]
indent_style = tab

# YAML files use 2 spaces
[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

# Terraform files use 2 spaces
[*.tf]
indent_size = 2

# Python files use 4 spaces
[*.py]
indent_size = 4

# Markdown (don't trim trailing whitespace to preserve formatting)
[*.md]
trim_trailing_whitespace = false

# Shell scripts (2 spaces)
[*.sh]
indent_size = 2
